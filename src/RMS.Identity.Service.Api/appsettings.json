{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileLogging": {
    "Enabled": true,
    "Path": "logs/application.log",
    "MinimumLevel": "Information"
  },
  "DatabaseLogging": {
    "Enabled": true,
    "ConnectionStringName": "Default",
    "TableName": "ApplicationLog",
    "MinimumLevel": "Warning",
    "CommandTimeoutSeconds": 5
  },
  "RateLimiting": {
    "Global": {
      "Enabled": true,
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true,
      "RejectionMessage": "Too many requests. Try again later."
    }
  },
  "ForwardedHeaders": {
    "Enabled": true,
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "CorrelationTrace": {
    "ResponseHeaderName": "X-Correlation-Trace-ID"
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Issuer": "RMS.Identity.Service",
    "Audience": "RMS",
    "SigningKey": "",
    "SigningKeyEnvVar": "JWT_SIGNING_KEY",
    "AccessTokenLifetimeSeconds": 3600,
    "RefreshTokenLifetimeDays": 30
  },
  "EmailDelivery": {
    "Enabled": false,
    "AutoVerifyByEndpoint": false,
    "VerifyEmailEndpointUrl": "http://localhost:5000/api/v1/users/verify-email",
    "FromAddress": "no-reply@example.com",
    "FromDisplayName": "RMS",
    "VerificationUrlTemplate": "https://example.com/verify-email?token={token}",
    "PollIntervalSeconds": 30,
    "BatchSize": 10,
    "MaxRetries": 5,
    "RetryDelaySeconds": 300,
    "ProcessingTimeoutSeconds": 300,
    "SmtpHost": "",
    "SmtpPort": 587,
    "EnableSsl": true,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "SmtpPasswordEnvVar": ""
  },
  "DataRetention": {
    "Enabled": true,
    "RunIntervalHours": 24,
    "RefreshTokenRetentionDays": 30,
    "VerificationTokenRetentionDays": 7,
    "IdempotencyRetentionDays": 7,
    "OutboxRetentionDays": 7,
    "BatchSize": 1000
  },
  "AllowedHosts": "*"
}
