{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileLogging": {
    "Enabled": true,
    "Path": "logs/application.development.log",
    "MinimumLevel": "Information"
  },
  "DatabaseLogging": {
    "Enabled": true,
    "ConnectionStringName": "Default",
    "TableName": "ApplicationLog",
    "MinimumLevel": "Warning",
    "CommandTimeoutSeconds": 5
  },
  "RateLimiting": {
    "Global": {
      "Enabled": true,
      "PermitLimit": 100,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true,
      "RejectionMessage": "Too many requests. Try again later."
    }
  },
  "ForwardedHeaders": {
    "Enabled": true,
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "CorrelationTrace": {
    "ResponseHeaderName": "X-Correlation-Trace-ID"
  },
  "ConnectionStrings": {
    "Default": "Server=127.0.0.1;Port=3306;Database=rms_identity;User ID=rms_user;Password=12345678;"
  },
  "Jwt": {
    "Issuer": "RMS.Identity.Service",
    "Audience": "RMS",
    "SigningKey": "replace-this-development-signing-key-with-a-secure-secret",
    "AccessTokenLifetimeSeconds": 3600,
    "RefreshTokenLifetimeDays": 30
  },
  "EmailDelivery": {
    "Enabled": false,
    "AutoVerifyByEndpoint": false,
    "VerifyEmailEndpointUrl": "http://localhost:5000/api/v1/users/verify-email",
    "FromAddress": "no-reply@example.com",
    "FromDisplayName": "RMS",
    "VerificationUrlTemplate": "https://localhost:5001/verify-email?token={token}",
    "PollIntervalSeconds": 30,
    "BatchSize": 10,
    "MaxRetries": 5,
    "RetryDelaySeconds": 300,
    "ProcessingTimeoutSeconds": 300,
    "SmtpHost": "",
    "SmtpPort": 587,
    "EnableSsl": true,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "SmtpPasswordEnvVar": ""
  }
}
